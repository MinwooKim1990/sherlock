# Copy this file to `.env` and fill in your actual keys.
# Sherlock auto-loads `.env` at config-load time via python-dotenv.
# `.env` is gitignored.

# Required for sherlock.live.yaml
ANTHROPIC_API_KEY=

# Optional — enables real Tavily web search; otherwise StubSearch fallback
TAVILY_API_KEY=

# Optional — for OpenAI embeddings (better retrieval than fake hashing)
OPENAI_API_KEY=

# Optional — Gemini direct (not needed; evaluator uses cli-wrapper-unified subscription auth)
GEMINI_API_KEY=
